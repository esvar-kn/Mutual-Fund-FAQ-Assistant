GROQ_API_KEY=your_groq_api_key_here

# Comma-separated browser origins allowed to call the API.
# Defaults to local dev; set this to your deployed frontend origin in production.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Abuse protection for /api/query (each request costs a Groq call).
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
MAX_QUERY_LENGTH=500

# Cap on how long a single Groq call may take before falling back.
GROQ_TIMEOUT_SECONDS=10
GROQ_MAX_RETRIES=1
